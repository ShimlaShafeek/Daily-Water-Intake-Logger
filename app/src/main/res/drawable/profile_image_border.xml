<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gradient ring -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#60A5FF"
                android:centerColor="#3B82F6"
                android:endColor="#0B5FFF"
                android:angle="270" />
            <size android:width="136dp" android:height="136dp" />
        </shape>
    </item>

    <!-- Inner transparent cutout to reveal the image and create a ring -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#00000000" />
            <size android:width="124dp" android:height="124dp" />
        </shape>
    </item>
</layer-list>
